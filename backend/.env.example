# FinStart backend - contoh konfigurasi lokal
NODE_ENV=development
PORT=4000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=finstart_db
DB_USER=root
DB_PASSWORD=
DB_POOL_SIZE=10

CORS_ORIGIN=http://localhost:5173
AUTH_SESSION_HOURS=8
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_LOCK_MINUTES=1

# Password demo ditulis plain text hanya di backend/.env lokal.
# Seeder akan melakukan hash sebelum menyimpan ke database.
DEMO_USER_EMAIL=finance@kedata.id
DEMO_USER_NAME=Finance Manager
DEMO_USER_PASSWORD=

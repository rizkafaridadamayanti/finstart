# FinStart backend
NODE_ENV=development
PORT=4000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=finstart_db
DB_USER=root
DB_PASSWORD=
DB_POOL_SIZE=10

CORS_ORIGIN=http://localhost:5173
AUTH_SESSION_HOURS=8
AUTH_RESET_TOKEN_MINUTES=30
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_LOCK_MINUTES=1
AUTH_SHOW_RESET_TOKEN=false

# Kredensial demo hanya disimpan di backend/.env lokal.
# Password di bawah harus berupa plain text; seeder akan meng-hash sebelum insert.
DEMO_USER_EMAIL=finance@kedata.id
DEMO_USER_NAME=Finance Manager
DEMO_USER_PASSWORD=

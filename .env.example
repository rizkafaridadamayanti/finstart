# Copy file ini menjadi ".env" di root project (sejajar dengan docker-compose.yml),
# lalu isi dengan nilai asli kamu. docker-compose otomatis membaca file ".env" ini.

# --- Database ---
DB_NAME=finstart_db
DB_USER=finstart
DB_PASSWORD=ganti-password-ini
DB_ROOT_PASSWORD=ganti-root-password-ini

# --- Backend ---
CORS_ORIGIN=http://localhost:5173
AUTH_SESSION_HOURS=8
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_LOCK_MINUTES=1
DEMO_USER_EMAIL=finance@kedata.id
DEMO_USER_NAME=Finance Manager
DEMO_USER_PASSWORD=ganti-password-demo-ini

# --- Frontend (di-bake saat build image, bukan runtime) ---
VITE_API_URL=http://localhost:4000/api

# Contoh konfigurasi untuk docker-compose.yml.
# Salin file ini jadi ".env" di folder yang sama, lalu sesuaikan nilainya.

# --- Database ---
DB_NAME=finstart_db
# DB_ROOT_PASSWORD: password root MySQL (dipakai healthcheck & admin).
# DB_USER/DB_PASSWORD: akun terpisah (bukan root) yang dipakai backend
# untuk konek ke database - lebih aman daripada backend pakai root.
DB_ROOT_PASSWORD=rootpassword
DB_USER=finstart
DB_PASSWORD=finstart
DB_PORT=3306
DB_POOL_SIZE=10

# --- Backend ---
BACKEND_PORT=4000
# PENTING: CORS_ORIGIN harus PERSIS SAMA dengan alamat frontend yang dibuka
# di browser, kalau tidak, login/semua request dari frontend akan gagal
# dengan error "Failed to fetch" karena diblokir CORS. Frontend selalu di
# port 80 (lihat catatan di bagian Frontend di bawah), jadi ini cukup
# http://localhost, atau http://domain-kamu kalau sudah pakai domain asli.
CORS_ORIGIN=http://localhost
AUTH_SESSION_HOURS=8
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_LOCK_MINUTES=1
DEMO_USER_EMAIL=finance@kedata.id
DEMO_USER_NAME=Finance Manager
DEMO_USER_PASSWORD=12345678
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# --- Frontend ---
# Port frontend dikunci 80:80 di docker-compose.yml (tidak bisa diganti
# lewat .env) - pastikan port 80 di komputer/server ini kosong (matikan
# Apache/Nginx/Laragon dulu kalau ada) sebelum menjalankan "docker compose up".
# VITE_API_URL dipakai saat build image (bukan saat runtime) - harus alamat
# backend yang bisa diakses BROWSER pengguna (bukan nama service docker
# "backend"), contoh: http://IP-ATAU-DOMAIN-SERVER:4000/api
VITE_API_URL=http://localhost:4000/api
